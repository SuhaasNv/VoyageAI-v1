// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
//  Enums
// ─────────────────────────────────────────

enum Role {
  USER
  ADMIN
  MODERATOR
}

// ─────────────────────────────────────────
//  User
// ─────────────────────────────────────────

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  passwordHash  String? // null for OAuth-only users (e.g. Google)
  name          String?
  image         String? // profile picture URL (e.g. from Google)
  role          Role    @default(USER)
  emailVerified Boolean @default(false)
  isActive      Boolean @default(true)

  // OAuth provider (e.g. "google") – when set, passwordHash is null
  provider   String?
  providerId String? // provider's unique user id (e.g. Google sub)

  hasOnboarded Boolean   @default(false)
  preferences  Json? // travel preferences from onboarding
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  trips            Trip[]
  travelPreference TravelPreference?
  favoriteDestinations FavoriteDestination[]

  @@index([email])
  @@index([provider, providerId])
  @@map("users")
}

// ─────────────────────────────────────────
//  Refresh Token (session store)
// ─────────────────────────────────────────

model RefreshToken {
  id        String @id @default(cuid())
  tokenHash String @unique // SHA-256 of the raw token (never store raw)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  family     String // rotation family – revoke on reuse
  isRevoked  Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  replacedBy String? // cuid of the token that superseded this one

  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
//  Audit Log
// ─────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String // e.g. LOGIN, LOGOUT, REFRESH, REGISTER
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
//  Rate Limit (DB-backed fallback)
// ─────────────────────────────────────────

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "ratelimit:login:ip:1.2.3.4"
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("rate_limit_entries")
}

// ─────────────────────────────────────────
//  LLM Call Log (usage tracking for cost awareness)
// ─────────────────────────────────────────

model AiUsageLog {
  id               String   @id @default(cuid())
  provider         String
  modelUsed        String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  latencyMs        Int
  costEstimateUsd  Float    @default(0)
  /// null = legacy row (before this column). false = explicit failure log. true = completed call.
  callSucceeded    Boolean?
  requestId        String?
  endpoint         String?
  createdAt        DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
  @@index([requestId])
  @@index([callSucceeded])
  @@map("ai_usage_logs")
}

// ─────────────────────────────────────────
//  Admin Action Log
// ─────────────────────────────────────────

model AdminActionLog {
  id         String   @id @default(cuid())
  /// One of the supported action types (CHECK_AI_PROVIDER, etc.)
  actionType String
  /// Input payload sent to the action executor.
  payload    Json?
  /// Result data returned by the executor.
  result     Json?
  success    Boolean
  /// Admin user who triggered the action.
  userId     String
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("admin_action_logs")
}

// ─────────────────────────────────────────
//  AI Decision Log (explainability layer)
// ─────────────────────────────────────────

model AiDecisionLog {
  id           String   @id @default(cuid())
  /// ASSISTANT_RESPONSE | AUTO_HEAL | AUTONOMOUS_ACTION | OPTIMIZATION
  decisionType String
  /// Which service produced this decision (admin_assistant | auto_healer | autonomous_runner)
  source       String
  /// Human-readable explanation of why the AI made this decision.
  reasoning    String
  /// Sanitized description of the data that informed the decision (no PII).
  inputSummary String
  /// 0–1 confidence derived from R², anomaly severity, or LLM assessment level.
  confidence   Float?
  /// What was recommended or what action was taken.
  outcome      String
  requestId    String?
  /// "admin:<userId>" | "autonomous" | "scheduled"
  triggeredBy  String?
  createdAt    DateTime @default(now())

  @@index([decisionType])
  @@index([createdAt])
  @@index([requestId])
  @@map("ai_decision_logs")
}

// ─────────────────────────────────────────
//  Agent Execution Log (structured replay)
// ─────────────────────────────────────────

model AgentExecutionLog {
  id          String   @id @default(cuid())
  /// Groups every step that belongs to one orchestrator pipeline run.
  requestId   String
  /// Agent name: planner | research | logistics | budget | safety | orchestrator
  agentName   String
  /// Zero-based position in the pipeline (preserves ordering).
  stepIndex   Int
  /// Sanitized input passed to the agent (no PII, truncated).
  inputJson   Json?
  /// Sanitized output produced by the agent (no PII, truncated).
  outputJson  Json?
  latencyMs   Int
  success     Boolean
  errorMsg    String?
  /// Extra context: tokens, model, provider — from AiUsageLog if available.
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([requestId])
  @@index([agentName])
  @@index([createdAt])
  @@map("agent_execution_logs")
}

// ─────────────────────────────────────────
//  Trip
// ─────────────────────────────────────────

model Trip {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination    String
  startDate      DateTime
  endDate        DateTime
  budgetTotal    Float    @default(0)
  budgetCurrency String   @default("USD")
  style          String? // relaxed | creative | exciting | luxury | budget
  imageUrl       String?
  shareToken     String?  @unique // UUID — null means private, set means publicly shareable
  /// draft = pipeline never completed; completed = itinerary saved successfully
  status         String   @default("draft")
  createdAt      DateTime @default(now())

  itineraries  Itinerary[]
  chatMessages ChatMessage[]

  @@index([userId])
  @@map("trips")
}

// ─────────────────────────────────────────
//  Itinerary
// ─────────────────────────────────────────

model Itinerary {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  rawJson   Json
  createdAt DateTime @default(now())

  @@index([tripId])
  @@map("itineraries")
}

// ─────────────────────────────────────────
//  ChatMessage
// ─────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([tripId])
  @@map("chat_messages")
}

// ─────────────────────────────────────────
//  TravelPreference
// ─────────────────────────────────────────

model TravelPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("travel_preferences")
}

// ─────────────────────────────────────────
//  Favorite Destination
// ─────────────────────────────────────────

model FavoriteDestination {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination String
  createdAt   DateTime @default(now())

  @@unique([userId, destination])
  @@index([userId])
  @@index([destination])
  @@map("favorite_destinations")
}
