{
  "title": "AI Performance",
  "uid": "voyageai-ai-performance",
  "tags": ["voyageai", "ai", "llm"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "title": "Total AI Requests (1h)",
      "targets": [{ "expr": "sum(increase(ai_requests_total[1h]))", "legendFormat": "Requests" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "title": "AI Failure Rate",
      "targets": [{
        "expr": "sum(rate(ai_failures_total[5m])) / sum(rate(ai_requests_total[5m]))",
        "legendFormat": "Failure Rate"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.1 }
          ]}
        }
      }
    },
    {
      "id": 3, "type": "stat", "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "title": "Tokens / min",
      "targets": [{ "expr": "sum(rate(ai_tokens_total{token_type='total'}[1m])) * 60", "legendFormat": "Tokens/min" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4, "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "title": "Estimated Cost Today (USD)",
      "targets": [{ "expr": "sum(increase(ai_cost_usd_total[24h]))", "legendFormat": "Cost" }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 5, "type": "stat", "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "title": "Fallback Rate",
      "targets": [{
        "expr": "sum(rate(ai_fallback_total[10m])) / sum(rate(ai_requests_total[10m]))",
        "legendFormat": "Fallback Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.25 }
          ]}
        }
      }
    },
    {
      "id": 6, "type": "stat", "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "title": "Active LLM Requests",
      "targets": [{ "expr": "sum(ai_active_requests)", "legendFormat": "In-flight" }]
    },
    {
      "id": 10, "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "title": "AI Request Latency (p50 / p95 / p99)",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11, "type": "timeseries", "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "title": "Token Usage by Provider",
      "targets": [
        { "expr": "sum(rate(ai_tokens_total{token_type='total'}[5m])) by (provider)", "legendFormat": "{{ provider }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 12, "type": "timeseries", "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "title": "AI Requests by Agent",
      "targets": [
        { "expr": "sum(rate(ai_requests_total[5m])) by (agent, status)", "legendFormat": "{{ agent }} ({{ status }})" }
      ]
    },
    {
      "id": 13, "type": "timeseries", "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "title": "LLM Fallbacks Over Time",
      "targets": [
        { "expr": "sum(rate(ai_fallback_total[5m])) by (from_provider, to_provider)", "legendFormat": "{{ from_provider }} → {{ to_provider }}" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "title": "AI Latency by Model",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (model, le))", "legendFormat": "p95 {{ model }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
