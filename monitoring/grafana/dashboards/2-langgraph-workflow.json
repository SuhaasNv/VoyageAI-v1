{
  "title": "LangGraph Workflow",
  "uid": "voyageai-langgraph",
  "tags": ["voyageai", "langgraph", "workflow"],
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "title": "Total Executions (1h)",
      "targets": [{ "expr": "sum(increase(langgraph_executions_total[1h]))", "legendFormat": "Executions" }]
    },
    {
      "id": 2, "type": "stat", "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "title": "Success Rate",
      "targets": [{
        "expr": "sum(rate(langgraph_executions_total{status='success'}[10m])) / sum(rate(langgraph_executions_total[10m]))",
        "legendFormat": "Success Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "green", "value": 0.95 }
          ]}
        }
      }
    },
    {
      "id": 3, "type": "stat", "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "title": "Active Executions",
      "targets": [{ "expr": "langgraph_active_executions", "legendFormat": "In-flight" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]}
        }
      }
    },
    {
      "id": 4, "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "title": "Requires Human (1h)",
      "targets": [{ "expr": "sum(increase(langgraph_executions_total{outcome='requires_human'}[1h]))" }]
    },
    {
      "id": 5, "type": "stat", "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "title": "Repair Iterations (1h)",
      "targets": [{ "expr": "sum(increase(langgraph_repair_iterations_total[1h]))" }]
    },
    {
      "id": 6, "type": "stat", "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "title": "Early Terminations (1h)",
      "targets": [{ "expr": "sum(increase(langgraph_early_termination_total[1h]))" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "id": 10, "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "title": "Graph Execution Duration (p50 / p95 / p99)",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(langgraph_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(langgraph_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(langgraph_execution_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11, "type": "timeseries", "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "title": "Executions by Outcome",
      "targets": [
        { "expr": "sum(rate(langgraph_executions_total[5m])) by (outcome)", "legendFormat": "{{ outcome }}" }
      ]
    },
    {
      "id": 20, "type": "bargauge", "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "title": "Node Execution Duration — p95 (Bottleneck Detection)",
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(langgraph_node_duration_seconds_bucket[10m])) by (node, le))",
        "legendFormat": "{{ node }}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 15 }
          ]}
        }
      }
    },
    {
      "id": 21, "type": "timeseries", "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "title": "Node Success vs Failure Rate",
      "targets": [
        { "expr": "sum(rate(langgraph_node_executions_total{status='success'}[5m])) by (node)", "legendFormat": "✅ {{ node }}" },
        { "expr": "sum(rate(langgraph_node_executions_total{status='error'}[5m])) by (node)", "legendFormat": "❌ {{ node }}" }
      ]
    },
    {
      "id": 22, "type": "timeseries", "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "title": "Branch Path Usage (Conditional Edges)",
      "targets": [{
        "expr": "sum(rate(langgraph_branch_path_total[5m])) by (from_node, to_node)",
        "legendFormat": "{{ from_node }} → {{ to_node }}"
      }]
    },
    {
      "id": 23, "type": "timeseries", "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "title": "Repair Loop Actions",
      "targets": [{
        "expr": "sum(rate(langgraph_repair_iterations_total[5m])) by (action)",
        "legendFormat": "{{ action }}"
      }]
    },
    {
      "id": 24, "type": "table", "gridPos": { "x": 0, "y": 28, "w": 24, "h": 6 },
      "title": "Node Error Breakdown",
      "targets": [{
        "expr": "sum(increase(langgraph_node_errors_total[1h])) by (node, error_type)",
        "legendFormat": "{{ node }} / {{ error_type }}"
      }],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    }
  ]
}
