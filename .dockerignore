# ─────────────────────────────────────────────────────────────────────────────
#  .dockerignore
#  Prevents large / sensitive files from entering any Docker build context.
#  Applies to ALL Dockerfiles in the project (root build context).
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER bake these into an image ─────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# ── Node / Next.js build artifacts ───────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
.vercel/

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/

# ── Test / CI artifacts ───────────────────────────────────────────────────────
coverage/
.nyc_output/
reports/
*.lcov
junit*.xml

# ── Editor / OS metadata ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Docker files themselves (not needed inside the image) ─────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── CI / GitHub Actions ───────────────────────────────────────────────────────
.github/

# ── Documentation / tooling ───────────────────────────────────────────────────
*.md
LICENSE
CHANGELOG*
scripts/
prisma/migrations/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
